# ==========================================================================
# UCU Mundial — Frontend Mobile (Expo)
# Copiá este archivo a ".env" y ajustá los valores a tu entorno.
# Solo las variables con prefijo EXPO_PUBLIC_ quedan disponibles en el bundle.
# ==========================================================================

# URL base del backend dockerizado puerto 5293.
# Elegí UNA según dónde corras la app:
#
#   - Emulador Android:        http://10.0.2.2:5293
#   - Simulador iOS / web:     http://localhost:5293
#   - Dispositivo físico:      http://<IP-LAN-de-tu-PC>:5293   (ej: http://192.168.0.12:5293)
#
# IMPORTANTE: en dispositivo físico NO sirve "localhost"; usá la IP de tu PC
# en la misma red Wi-Fi y asegurate de que el contenedor exponga el 5293.
# recomendamos el comando ipconfig para verificar la misma.

EXPO_PUBLIC_API_URL=http://10.0.2.2:5293